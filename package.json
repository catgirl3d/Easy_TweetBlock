{
  "name": "easy-tweetblock",
  "private": true,
  "description": "Cross-browser build skeleton for the Easy TweetBlock extension.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "lint": "npx --yes web-ext@10.4.0 lint --source-dir dist/firefox-package",
    "build:manifest:firefox": "node scripts/build-manifest.js firefox dist/firefox-package",
    "build:manifest:chrome": "node scripts/build-manifest.js chrome dist/chrome-package",
    "stage:firefox": "node scripts/stage-extension.js firefox",
    "stage:chrome": "node scripts/stage-extension.js chrome",
    "package:firefox": "node scripts/package-extension.js firefox",
    "package:chrome": "node scripts/package-extension.js chrome",
    "package": "npm run package:firefox && npm run package:chrome",
    "validate:release-tag": "node scripts/validate-release-tag.js",
    "extract-release-notes": "node scripts/extract-release-notes.js",
    "build:production:firefox": "npm run package:firefox",
    "build:production:chrome": "npm run package:chrome",
    "build:production": "npm test && npm run package",
    "build": "npm run build:production"
  },
  "devDependencies": {
    "yauzl": "3.4.0",
    "yazl": "3.3.1"
  }
}
