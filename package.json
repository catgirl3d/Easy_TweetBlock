{
  "name": "easy-tweetblock",
  "private": true,
  "description": "Cross-browser build skeleton for the Easy TweetBlock extension.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "build:manifest:firefox": "node scripts/build-manifest.js firefox dist/firefox-package",
    "build:manifest:chrome": "node scripts/build-manifest.js chrome dist/chrome-package",
    "stage:firefox": "node scripts/stage-extension.js firefox",
    "stage:chrome": "node scripts/stage-extension.js chrome",
    "build": "npm test && npm run stage:firefox && npm run stage:chrome"
  }
}
